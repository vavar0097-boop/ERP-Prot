{
  "name": "erp-besi",
  "version": "1.0.0",
  "description": "ERP sistem distributor besi B2B/B2C",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@erp-besi/api\" \"npm run dev --workspace=@erp-besi/web\"",
    "build": "npm run build --workspace=apps/api --workspace=apps/web && rm -rf dist && cp -R apps/web/dist dist",
    "build:web": "npm run build --workspace=@erp-besi/web && rm -rf dist && cp -R apps/web/dist dist",
    "railway:build": "npm run build --workspace=@erp-besi/api",
    "railway:preflight": "node apps/api/scripts/check-railway-env.mjs",
    "railway:start": "npm run railway:preflight && npm run railway:migrate && npm run start --workspace=@erp-besi/api",
    "railway:migrate": "node apps/api/scripts/prisma-migrate-deploy.mjs",
    "deploy:env": "node scripts/check-deploy-env.mjs",
    "type-check": "npm run type-check --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "keywords": [
    "erp",
    "besi",
    "distributor",
    "inventory"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
