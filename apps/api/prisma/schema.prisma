generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIAL_DELIVERED
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum DeliveryStatus {
  DRAFT
  READY
  ON_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ProductUnit {
  PCS
  KG
  TON
  BATANG
}

model Supplier {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  phone          String?
  email          String?
  address        String?
  contactPerson  String?         @map("contact_person")
  isActive       Boolean         @default(true) @map("is_active")
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("suppliers")
}

model CustomerPriceLevel {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  customers   Customer[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("customer_price_levels")
}

model Customer {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  type              String              @default("B2C")
  phone             String?
  email             String?
  address           String?
  taxNumber         String?             @map("tax_number")
  paymentTermDays   Int                 @default(0) @map("payment_term_days")
  priceLevelId      String?             @map("price_level_id")
  priceLevel        CustomerPriceLevel? @relation(fields: [priceLevelId], references: [id])
  isActive          Boolean             @default(true) @map("is_active")
  salesOrders       SalesOrder[]
  invoices          Invoice[]
  payments          Payment[]
  deliveryOrders    DeliveryOrder[]
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@map("customers")
}

model ProductCategory {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("product_categories")
}

model Product {
  id               String                  @id @default(cuid())
  sku              String                  @unique
  name             String
  categoryId       String?                 @map("category_id")
  category         ProductCategory?        @relation(fields: [categoryId], references: [id])
  type             String
  shapeProfile     String                  @map("shape_profile")
  sizeText         String                  @map("size_text")
  lengthMm         Int?                    @map("length_mm")
  weightKgPerPiece Decimal?                @map("weight_kg_per_piece") @db.Decimal(12, 3)
  unit             ProductUnit             @default(BATANG)
  minimumStock     Decimal                 @default(0) @map("minimum_stock") @db.Decimal(14, 3)
  isActive         Boolean                 @default(true) @map("is_active")
  stocks           Stock[]
  stockMovements   StockMovement[]
  purchaseItems    PurchaseOrderItem[]
  receiptItems     GoodsReceiptItem[]
  salesItems       SalesOrderItem[]
  invoiceItems     InvoiceItem[]
  deliveryItems    DeliveryOrderItem[]
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  @@map("products")
}

model StockLocation {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  address     String?
  stocks      Stock[]
  movements   StockMovement[]
  receiptItems GoodsReceiptItem[]
  deliveryItems DeliveryOrderItem[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("stock_locations")
}

model Stock {
  id         String        @id @default(cuid())
  productId  String        @map("product_id")
  product    Product       @relation(fields: [productId], references: [id])
  locationId String        @map("location_id")
  location   StockLocation @relation(fields: [locationId], references: [id])
  quantity   Decimal       @default(0) @db.Decimal(14, 3)
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@unique([productId, locationId])
  @@map("stocks")
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String            @map("product_id")
  product       Product           @relation(fields: [productId], references: [id])
  locationId    String            @map("location_id")
  location      StockLocation     @relation(fields: [locationId], references: [id])
  movementType  StockMovementType @map("movement_type")
  quantity      Decimal           @db.Decimal(14, 3)
  referenceType String?           @map("reference_type")
  referenceId   String?           @map("reference_id")
  remarks       String?
  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([productId, locationId])
  @@map("stock_movements")
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  supplierId    String              @map("supplier_id")
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  poNumber      String              @unique @map("po_number")
  status        PurchaseOrderStatus @default(DRAFT)
  orderDate     DateTime            @default(now()) @map("order_date")
  expectedDate  DateTime?           @map("expected_date")
  totalAmount   Decimal             @default(0) @map("total_amount") @db.Decimal(16, 2)
  items         PurchaseOrderItem[]
  receipts      GoodsReceipt[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String        @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String        @map("product_id")
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 3)
  receivedQty     Decimal       @default(0) @map("received_qty") @db.Decimal(14, 3)
  unitPrice       Decimal       @map("unit_price") @db.Decimal(16, 2)
  lineTotal       Decimal       @map("line_total") @db.Decimal(16, 2)

  @@map("purchase_order_items")
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  purchaseOrderId String             @map("purchase_order_id")
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  receiptNumber   String             @unique @map("receipt_number")
  receiptDate     DateTime           @default(now()) @map("receipt_date")
  remarks         String?
  items           GoodsReceiptItem[]
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             String       @id @default(cuid())
  goodsReceiptId String       @map("goods_receipt_id")
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  productId      String       @map("product_id")
  product        Product      @relation(fields: [productId], references: [id])
  locationId     String       @map("location_id")
  location       StockLocation @relation(fields: [locationId], references: [id])
  quantity       Decimal      @db.Decimal(14, 3)

  @@map("goods_receipt_items")
}

model SalesOrder {
  id              String             @id @default(cuid())
  customerId      String             @map("customer_id")
  customer        Customer           @relation(fields: [customerId], references: [id])
  soNumber        String             @unique @map("so_number")
  status          SalesOrderStatus   @default(DRAFT)
  orderDate       DateTime           @default(now()) @map("order_date")
  totalAmount     Decimal            @default(0) @map("total_amount") @db.Decimal(16, 2)
  paymentTermDays Int                @default(0) @map("payment_term_days")
  items           SalesOrderItem[]
  invoices        Invoice[]
  deliveryOrders  DeliveryOrder[]
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("sales_orders")
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String     @map("sales_order_id")
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  productId    String     @map("product_id")
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Decimal    @db.Decimal(14, 3)
  deliveredQty Decimal    @default(0) @map("delivered_qty") @db.Decimal(14, 3)
  unitPrice    Decimal    @map("unit_price") @db.Decimal(16, 2)
  lineTotal    Decimal    @map("line_total") @db.Decimal(16, 2)

  @@map("sales_order_items")
}

model Invoice {
  id            String              @id @default(cuid())
  invoiceNumber String              @unique @map("invoice_number")
  salesOrderId  String              @map("sales_order_id")
  salesOrder    SalesOrder          @relation(fields: [salesOrderId], references: [id])
  customerId    String              @map("customer_id")
  customer      Customer            @relation(fields: [customerId], references: [id])
  invoiceDate   DateTime            @default(now()) @map("invoice_date")
  dueDate       DateTime            @map("due_date")
  totalAmount   Decimal             @map("total_amount") @db.Decimal(16, 2)
  paidAmount    Decimal             @default(0) @map("paid_amount") @db.Decimal(16, 2)
  status        InvoiceStatus       @default(UNPAID)
  items         InvoiceItem[]
  allocations   PaymentAllocation[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  description String?
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(16, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(16, 2)

  @@map("invoice_items")
}

model Payment {
  id             String              @id @default(cuid())
  customerId     String              @map("customer_id")
  customer       Customer            @relation(fields: [customerId], references: [id])
  paymentNumber  String              @unique @map("payment_number")
  paymentDate    DateTime            @default(now()) @map("payment_date")
  amount         Decimal             @db.Decimal(16, 2)
  method         String?
  referenceNo    String?             @map("reference_no")
  remarks        String?
  allocations    PaymentAllocation[]
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@map("payments")
}

model PaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String  @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  amount    Decimal @db.Decimal(16, 2)

  @@map("payment_allocations")
}

model Vehicle {
  id             String          @id @default(cuid())
  plateNumber    String          @unique @map("plate_number")
  name           String
  type           String?
  capacityKg     Decimal?        @map("capacity_kg") @db.Decimal(14, 3)
  isActive       Boolean         @default(true) @map("is_active")
  deliveryOrders DeliveryOrder[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("vehicles")
}

model Driver {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  licenseNumber  String?         @map("license_number")
  isActive       Boolean         @default(true) @map("is_active")
  deliveryOrders DeliveryOrder[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("drivers")
}

model DeliveryOrder {
  id            String              @id @default(cuid())
  doNumber      String              @unique @map("do_number")
  salesOrderId  String              @map("sales_order_id")
  salesOrder    SalesOrder          @relation(fields: [salesOrderId], references: [id])
  customerId    String              @map("customer_id")
  customer      Customer            @relation(fields: [customerId], references: [id])
  vehicleId     String?             @map("vehicle_id")
  vehicle       Vehicle?            @relation(fields: [vehicleId], references: [id])
  driverId      String?             @map("driver_id")
  driver        Driver?             @relation(fields: [driverId], references: [id])
  status        DeliveryStatus      @default(DRAFT)
  deliveryDate  DateTime?           @map("delivery_date")
  deliveredAt   DateTime?           @map("delivered_at")
  items         DeliveryOrderItem[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("delivery_orders")
}

model DeliveryOrderItem {
  id              String        @id @default(cuid())
  deliveryOrderId String        @map("delivery_order_id")
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id])
  productId       String        @map("product_id")
  product         Product       @relation(fields: [productId], references: [id])
  locationId      String        @map("location_id")
  location        StockLocation @relation(fields: [locationId], references: [id])
  quantity        Decimal       @db.Decimal(14, 3)

  @@map("delivery_order_items")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  actorId    String?  @map("actor_id")
  remarks    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("audit_logs")
}
